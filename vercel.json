{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routes": [
        {
          "src": "/(.*)",
          "dest": "/$1"
        }
      ]
    },
    "backend": {
      "entrypoint": "backend",
      "routes": [
        {
          "src": "/api/(.*)",
          "dest": "/$1"
        }
      ]
    }
  }
}